data = {
    "Order_ID": [501, 502, 503, 504, 505],
    "Customer": ["Siam", "Nabila", "Fahim", "Nabila", "Siam"],
    "Item": ["Cold Coffee", "Chicken Fry", "Masala Chai", "Cold Coffee", "Chicken Fry"],
    "Category": ["Drinks", "Snacks", "Drinks", "Drinks", "Snacks"],
    "Quantity": [2, 3, 4, 1, 2],
    "Price_Per_Unit": [120, 150, 40, 120, 150],
    "Discount_Percent": [10, 0, 5, 10, 0]
}
import pandas as pd
df = pd.DataFrame(data)
df["Total_Bills"] = df["Price_Per_Unit"] * df["Quantity"]
df["Discount"] = df["Total_Bills"] * (df["Discount_Percent"] * .01)
df["Final_Bills"] = df["Total_Bills"] - df["Discount"]
df
